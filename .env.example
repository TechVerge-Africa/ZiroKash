# ZiroKash Environment Variables

# ===== REQUIRED =====

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ===== OPTIONAL (AI Features) =====

# Google Gemini API Key (for AI Form Generator)
# Get your key from: https://ai.google.dev/
# Without this key, AI form generation will fallback to smart templates
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ===== NOTES =====
# 1. Copy this file to .env and fill in your actual values
# 2. Never commit .env to version control (.gitignore should exclude it)
# 3. The AI form generator will work without GEMINI_API_KEY using fallback mode
# 4. Restart your dev server after changing environment variables
